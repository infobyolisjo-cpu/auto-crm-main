# ByOlisJo CRM — Variables de Entorno
# Copia como: cp .env.example .env.local

# =============================================================================
# BASE DE DATOS — REQUERIDA en producción
# Local dev: crea una rama gratis en https://neon.tech
# Producción: Vercel Dashboard → Storage → Add → Neon (se configura solo)
# =============================================================================
DATABASE_URL=postgres://user:pass@host/db?sslmode=require

# =============================================================================
# WEBHOOK SECRET — Protege /api/webhook de requests no autorizadas
# Generar: openssl rand -hex 32
# Usar el mismo valor en Vercel y en cada sistema que te envía leads
# =============================================================================
WEBHOOK_SECRET=ae82dd4486874621e147e943fc79ae52606d099c6e00925e073ab742a50df47e

# =============================================================================
# CRM AUTH — Protege dashboard, páginas privadas y APIs internas
# Producción/Preview: configura ambos valores en Vercel
# =============================================================================
CRM_AUTH_USERNAME=admin
CRM_AUTH_PASSWORD=cambia-este-password

# =============================================================================
# EMAIL — Digest diario a byolisjo@gmail.com
# Registro gratuito en https://resend.com
# =============================================================================
RESEND_API_KEY=re_...
DIGEST_EMAIL=byolisjo@gmail.com
DIGEST_FROM=ByOlisJo CRM <onboarding@resend.dev>

# =============================================================================
# IA — Clasificación automática de leads (opcional)
# Sin esta key el CRM usa scoring por reglas y funciona igual
# =============================================================================
ANTHROPIC_API_KEY=sk-ant-...

# =============================================================================
# URL pública del CRM (para CORS en byolisjo.com si es necesario)
# =============================================================================
NEXT_PUBLIC_CRM_URL=https://tu-crm.vercel.app

# =============================================================================
# CÓMO ENVIAR LEADS AL WEBHOOK — Ejemplos por canal
#
# byolisjo.com (formulario web):
#   POST https://tu-crm.vercel.app/api/webhook
#   Header: x-outreach-secret: <WEBHOOK_SECRET>
#   Body: { name, email, phone, message, source:"website", channel:"web" }
#
# WhatsApp (whatsapp-agentkit-3.onrender.com):
#   POST https://tu-crm.vercel.app/api/webhook
#   Header: x-outreach-secret: <WEBHOOK_SECRET>
#   Body: { name, phone, notes, source:"whatsapp", channel:"whatsapp" }
#
# Instagram (via Zapier/Make):
#   Body: { name, notes, source:"instagram", channel:"instagram" }
#
# LinkedIn (via Zapier/Make):
#   Body: { name, email, notes, source:"linkedin", channel:"linkedin" }
# =============================================================================
